# GigShield Backend Environment Variables
# Copy this file to .env and fill in your values

# OpenWeatherMap API Key (free tier: https://openweathermap.org/api)
WEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Server
PORT=3000

# Database
DB_HOST=gigshield_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=gigshield
DB_PORT=5432

# Admin Credentials (change these in production!)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change_this_password
ADMIN_TOKEN_SECRET=change_this_secret_key

# ML Risk Prediction Service
ML_SERVICE_URL=http://localhost:8001

# Environment (set to 'production' in prod to enforce OTP verification)
NODE_ENV=development

# Razorpay Payment Gateway (Test Mode)
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here
